{
  "name": "presentation-web-v1",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A literary essay rendered as a scroll-driven, keyboard-navigable web presentation.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:ci": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "parse-content": "tsx src/build/parse-content.ts",
    "build:pptx": "tsx scripts/build-pptx.ts",
    "build:playbook": "tsx scripts/build-playbook.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "postcss": "^8.4.0",
    "postcss-preset-env": "^10.0.0",
    "pptxgenjs": "^4.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "gsap": "^3.13.0"
  }
}
